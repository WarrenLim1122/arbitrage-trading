//@version=6
indicator("TEST-ONLY 15m Loop (Webhook Pinger)", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// ═══════════════════════════════════════════════════════════════════════════
//  ⚠️  TEST-ONLY — NOT A STRATEGY  ⚠️
// ───────────────────────────────────────────────────────────────────────────
//  Purpose: exercise the full Layer 1 → 2 → 3 pipeline on a DEMO account.
//
//  Behavior (no edge, no market analysis):
//    1. Watch for swing pivots using the SAME logic as the production
//       indicator (`ta.pivothigh` / `ta.pivotlow` with N = inPivotN, default
//       6 — matches the production HL / HH / LH / LL labels).
//    2. When ARMED + the latest swing pair brackets price
//       (lastSwingLow < close < lastSwingHigh), fire a webhook in a random
//       direction. Anchor SL and TP directly to the swings:
//         LONG  → SL = lastSwingLow,  TP = lastSwingHigh
//         SHORT → SL = lastSwingHigh, TP = lastSwingLow
//    3. Wait for the virtual trade to touch SL or TP, remember which
//       (the "memory placeholder" → diag table 'Last close' = TP / SL / —).
//    4. After close, wait a random 1–5 bar gap, then try again.
//    5. If price breaks outside the latest swing range, the indicator stays
//       silent until a new confirmed swing brings it back inside.
//
//  RR is no longer an input — it's implicit (whatever the swing geometry
//  gives at the moment of entry). The frozen production file
//  (`1D-15m Breakout INDICATOR.pine`) is untouched.
//
//  DO NOT attach this to any chart once real capital is live.
//  Note: TradingView never fires alerts on historical bars — webhooks start
//  once you create the alert and a new 15m bar closes.
// ═══════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════
bool   inEnabled    = input.bool(true,   "Enabled (master kill switch)")
int    inMaxPerDay  = input.int(20,      "Max signals per UTC day", minval=1)
int    inPivotN     = input.int(6,       "Pivot length (bars on each side)", minval=1, tooltip="Defines a swing. 6 matches the production indicator's HL/HH/LH/LL labels. Smaller = more frequent swings = more frequent test trades.")
float  inMinSlPct   = input.float(0.02,  "Safety: min SL distance (% of price)", minval=0.0, step=0.01, tooltip="If the swing-based SL is closer than this %, the trade is skipped to avoid broker rejection of a too-tight stop. Set 0 to disable.")
bool   inShowPivots = input.bool(true,   "Show swing pivot labels (HH HL LH LL)")
string inOrderType  = input.string("MARKET", "Order type", options=["MARKET", "LIMIT"])
bool   inShowTable  = input.bool(true,   "Show diagnostic table")

string pip_type = syminfo.ticker == "USDJPY" ? "jpy" : "standard"
float  pip_size = syminfo.ticker == "USDJPY" ? 0.01 : 0.0001

// ═══════════════════════════════════════════════════════════════════════════
// SWING (LTF PIVOT) DETECTION — mirrors the production indicator exactly
// ═══════════════════════════════════════════════════════════════════════════
float pivHigh = ta.pivothigh(high, inPivotN, inPivotN)
float pivLow  = ta.pivotlow(low,   inPivotN, inPivotN)

var float lastSwingHigh = na
var float lastSwingLow  = na
var float prevSwingHigh = na
var float prevSwingLow  = na

if not na(pivHigh)
    float newSh = high[inPivotN]
    string lbl  = na(prevSwingHigh) ? "SH" : (newSh > prevSwingHigh ? "HH" : "LH")
    if inShowPivots
        label.new(bar_index[inPivotN], newSh, lbl, color=color.new(color.orange, 40), style=label.style_label_down, textcolor=color.white, size=size.small)
    prevSwingHigh := lastSwingHigh
    lastSwingHigh := newSh

if not na(pivLow)
    float newSl = low[inPivotN]
    string lbl  = na(prevSwingLow) ? "SL" : (newSl > prevSwingLow ? "HL" : "LL")
    if inShowPivots
        label.new(bar_index[inPivotN], newSl, lbl, color=color.new(color.aqua, 40), style=label.style_label_up, textcolor=color.white, size=size.small)
    prevSwingLow := lastSwingLow
    lastSwingLow := newSl

// ═══════════════════════════════════════════════════════════════════════════
// STATE
//   state: 0 = ARMED   1 = IN_TRADE   2 = COOLDOWN
//   lastCloseType: "TP" / "SL" / "—"   ← memory placeholder
//   nextGap: bars to wait this cooldown (re-rolled per close, 1–5 inclusive)
// ═══════════════════════════════════════════════════════════════════════════
var int    state          = 0
var int    vDir           = 0
var float  vEntry         = na
var float  vSl            = na
var float  vTp            = na
var int    cooldownCount  = 0
var int    nextGap        = 1
var int    signalsToday   = 0
var int    lastDay        = na
var string lastCloseType  = "—"
var box    bxReward       = na
var box    bxRisk         = na
var line   lnEntry        = na
var line   lnSl           = na
var line   lnTp           = na

bool fireLong  = false
bool fireShort = false

// ═══════════════════════════════════════════════════════════════════════════
// STATE MACHINE — advances only on confirmed (closed) 15m bars so it stays
// in lock-step with alert.freq_once_per_bar_close.
// ═══════════════════════════════════════════════════════════════════════════
if barstate.isconfirmed
    // ── Daily cap reset (UTC) ─────────────────────────────────────────────
    int curDay = int(math.floor(time / 86400000.0))
    if na(lastDay) or curDay != lastDay
        signalsToday := 0
        lastDay      := curDay

    // ── 1. IN_TRADE → extend boxes/lines to this bar, then check touch ────
    if state == 1
        if not na(bxReward)
            box.set_right(bxReward, bar_index)
            box.set_right(bxRisk,   bar_index)
            line.set_x2(lnEntry, bar_index)
            line.set_x2(lnSl,    bar_index)
            line.set_x2(lnTp,    bar_index)
        bool hitTp = vDir == 1 ? high >= vTp : low  <= vTp
        bool hitSl = vDir == 1 ? low  <= vSl : high >= vSl
        if hitTp or hitSl
            lastCloseType := hitTp ? "TP" : "SL"
            state         := 2
            cooldownCount := 0
            nextGap       := int(math.random(1, 6))   // 1..5 inclusive

    // ── 2. COOLDOWN → tick down, then re-arm ──────────────────────────────
    else if state == 2
        cooldownCount += 1
        if cooldownCount >= nextGap
            state := 0

    // ── 3. ARMED → fire only if the latest swing pair brackets price ──────
    if state == 0 and inEnabled and signalsToday < inMaxPerDay
        bool haveSwings = not na(lastSwingHigh) and not na(lastSwingLow)
        bool inRange    = haveSwings and lastSwingLow < close and lastSwingHigh > close
        if inRange
            int   dir     = math.random(0, 1) < 0.5 ? 1 : -1
            float entryPx = close
            float slPx    = dir == 1 ? lastSwingLow  : lastSwingHigh
            float tpPx    = dir == 1 ? lastSwingHigh : lastSwingLow
            float slDist  = math.abs(entryPx - slPx)
            float minDist = entryPx * inMinSlPct / 100.0
            if inMinSlPct == 0 or slDist >= minDist
                vDir     := dir
                vEntry   := entryPx
                vSl      := slPx
                vTp      := tpPx
                state    := 1
                signalsToday += 1
                fireLong  := dir == 1
                fireShort := dir == -1

                // Visualization — start 1 bar wide; the IN_TRADE branch
                // extends the right edge each bar until SL/TP touches.
                lnEntry := line.new(bar_index, entryPx, bar_index + 1, entryPx, color=color.white, style=line.style_solid)
                lnSl    := line.new(bar_index, slPx,    bar_index + 1, slPx,    color=color.red,   style=line.style_dashed)
                lnTp    := line.new(bar_index, tpPx,    bar_index + 1, tpPx,    color=color.green, style=line.style_dashed)
                if dir == 1
                    bxReward := box.new(bar_index, tpPx,    bar_index + 1, entryPx, border_color=na, bgcolor=color.new(color.green, 85))
                    bxRisk   := box.new(bar_index, entryPx, bar_index + 1, slPx,    border_color=na, bgcolor=color.new(color.red,   85))
                else
                    bxReward := box.new(bar_index, entryPx, bar_index + 1, tpPx,    border_color=na, bgcolor=color.new(color.green, 85))
                    bxRisk   := box.new(bar_index, slPx,    bar_index + 1, entryPx, border_color=na, bgcolor=color.new(color.red,   85))

                // Webhook payload — schema-identical to the production
                // indicator. rr_ratio is computed from the swing geometry
                // (implicit, not an input), so downstream lot-sizing logic
                // still sees a numeric value for the field it expects.
                string sigStr   = dir == 1 ? "LONG" : "SHORT"
                string trendStr = dir == 1 ? "BULLISH" : "BEARISH"
                float  slPips   = slDist / pip_size
                float  slPct    = slDist / entryPx * 100.0
                float  rrOut    = math.abs(tpPx - entryPx) / slDist
                string payload = '{"signal":"' + sigStr + '","ticker":"' + syminfo.ticker + '","timestamp_ms":' + str.tostring(time) + ',"timeframe":"15m","entry":' + str.tostring(entryPx) + ',"sl":' + str.tostring(slPx) + ',"tp":' + str.tostring(tpPx) + ',"sl_pips":' + str.tostring(slPips) + ',"sl_percent":' + str.tostring(slPct) + ',"rr_ratio":' + str.tostring(rrOut) + ',"order_type":"' + inOrderType + '","daily_trend":"' + trendStr + '","m15_swing_high":' + str.tostring(lastSwingHigh) + ',"m15_swing_low":' + str.tostring(lastSwingLow) + ',"pip_type":"' + pip_type + '"}'
                alert(payload, alert.freq_once_per_bar_close)

// ═══════════════════════════════════════════════════════════════════════════
// VISUALS — entry-bar markers
// ═══════════════════════════════════════════════════════════════════════════
plotshape(fireLong,  title="LONG fired",  style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.small, text="L")
plotshape(fireShort, title="SHORT fired", style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.small, text="S")

// ═══════════════════════════════════════════════════════════════════════════
// DIAGNOSTIC TABLE
// ═══════════════════════════════════════════════════════════════════════════
var table panel = table.new(position.top_right, 2, 7, border_width=1, border_color=color.gray)

if barstate.islast and inShowTable
    string stateStr = not inEnabled ? "DISABLED" : state == 0 ? "ARMED" : state == 1 ? "IN TRADE" : "COOLDOWN"
    color  stateBg  = not inEnabled ? color.new(color.gray, 40) : state == 1 ? color.new(color.aqua, 40) : state == 2 ? color.new(color.orange, 40) : color.new(color.green, 40)

    bool   haveSwings = not na(lastSwingHigh) and not na(lastSwingLow)
    bool   inRange    = haveSwings and lastSwingLow < close and lastSwingHigh > close
    string rangeStr   = not haveSwings ? "waiting…" : inRange ? "YES" : "NO (outside)"
    color  rangeBg    = not haveSwings ? color.new(color.gray, 40) : inRange ? color.new(color.green, 60) : color.new(color.red, 60)

    table.cell(panel, 0, 0, "TEST-ONLY Loop", bgcolor=color.new(color.black, 10), text_color=color.yellow, text_size=size.small)
    table.cell(panel, 1, 0, stateStr, bgcolor=stateBg, text_color=color.white, text_size=size.small)

    table.cell(panel, 0, 1, "Inside swing range", bgcolor=color.new(color.black, 20), text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 1, rangeStr, bgcolor=rangeBg, text_color=color.white, text_size=size.tiny)

    table.cell(panel, 0, 2, "Last close", bgcolor=color.new(color.black, 20), text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 2, lastCloseType, bgcolor=color.new(color.black, 20), text_color=lastCloseType == "TP" ? color.lime : lastCloseType == "SL" ? color.red : color.silver, text_size=size.tiny)

    table.cell(panel, 0, 3, "Signals today", bgcolor=color.new(color.black, 20), text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 3, str.tostring(signalsToday) + " / " + str.tostring(inMaxPerDay), bgcolor=color.new(color.black, 20), text_color=signalsToday >= inMaxPerDay ? color.orange : color.white, text_size=size.tiny)

    table.cell(panel, 0, 4, "Cooldown left", bgcolor=color.new(color.black, 20), text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 4, state == 2 ? str.tostring(math.max(nextGap - cooldownCount, 0)) + " / " + str.tostring(nextGap) + " bar(s)" : "—", bgcolor=color.new(color.black, 20), text_color=color.white, text_size=size.tiny)

    table.cell(panel, 0, 5, "Virtual E / SL / TP", bgcolor=color.new(color.black, 20), text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 5, state == 1 ? str.tostring(vEntry, format.mintick) + " / " + str.tostring(vSl, format.mintick) + " / " + str.tostring(vTp, format.mintick) : "—", bgcolor=color.new(color.black, 20), text_color=color.white, text_size=size.tiny)

    table.cell(panel, 0, 6, "Order type", bgcolor=color.new(color.black, 20), text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 6, inOrderType, bgcolor=color.new(color.black, 20), text_color=color.white, text_size=size.tiny)
