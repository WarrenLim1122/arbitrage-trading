# Copy this file to .env and fill in real values. Never commit .env to git.

# ── Layer 1 — Gatekeeper (VPS #1) ─────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_key_here
LAYER2_URL=http://127.0.0.1:8001/signal
NEWS_WINDOW_MINUTES=30
# NEWS_FAIL_OPEN=true  → pass signal through if Finnhub is unreachable (default)
# NEWS_FAIL_OPEN=false → suppress signal if Finnhub is unreachable (safer)
NEWS_FAIL_OPEN=true

# ── Layer 2 — Logic Core (VPS #1) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Layer 3 — Prop worker (VPS #2, .env on VPS #2 only) ───────────────────
MT5_LOGIN=your_fundingpips_account_number
MT5_PASSWORD=your_fundingpips_password
MT5_SERVER=FundingPips-Live
# ZMQ_PULL_ADDR=tcp://0.0.0.0:5555   ← default, no need to set
# ZMQ_REP_ADDR=tcp://0.0.0.0:5556    ← default, no need to set

# ── Layer 3 — Personal worker (VPS #3, .env on VPS #3 only) ───────────────
# MT5_LOGIN=your_fusionmarkets_account_number
# MT5_PASSWORD=your_fusionmarkets_password
# MT5_SERVER=FusionMarkets-Live
