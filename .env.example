# Copy this file to .env and fill in real values. Never commit .env to git.

# ── Layer 1 — Gatekeeper (VPS #1) ─────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_key_here
LAYER2_URL=http://127.0.0.1:8001/signal
NEWS_WINDOW_MINUTES=30
# NEWS_FAIL_OPEN=true  → pass signal through if Finnhub is unreachable (default)
# NEWS_FAIL_OPEN=false → suppress signal if Finnhub is unreachable (safer)
NEWS_FAIL_OPEN=true

# ── Layer 2 — Logic Core (VPS #1) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Layer 3 — Personal worker (VPS #2, .env on VPS #2 only) ──────────────
MT5_LOGIN=your_fusionmarkets_account_number
MT5_PASSWORD=your_fusionmarkets_password
MT5_SERVER=FusionMarkets-Live
# ZMQ_PULL_ADDR=tcp://0.0.0.0:5555   ← default, no need to set
# ZMQ_REP_ADDR=tcp://0.0.0.0:5556    ← default, no need to set

# ── Layer 3 — Prop worker (VPS #3, .env on VPS #3 only) ───────────────────
# MT5_LOGIN=your_fundingpips_account_number
# MT5_PASSWORD=your_fundingpips_password
# MT5_SERVER=FundingPips-Live

# ── Layer 3 — Execution mode ───────────────────────────────────────────────
# Layer 2 now sends order_type=market in both personal and prop tickets, so
# LIMIT_ONLY_EXECUTION is effectively bypassed for all signal-driven trades.
# Set to false only if you want to override this at the worker level.
# LIMIT_ONLY_EXECUTION=true

# ── Layer 3 — Trade journaling (both VPS #2 and VPS #3) ───────────────────
# Master switch — set to true to activate the journal pipeline
FIREBASE_JOURNAL_ENABLED=false

# Dry-run: build payload + log it, but do NOT write to Firestore or upload screenshots.
# Set to false only after confirming the dry-run payload looks correct.
FIREBASE_JOURNAL_DRY_RUN=true

# Firebase project (find in Firebase Console → Project settings → General)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Path to the service account JSON key file on this VPS (absolute path recommended)
# Download from Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=C:\path\to\serviceAccountKey.json

# The Firestore user document that owns these trades.
# Find it in Firebase Console → Authentication → Users → copy the User UID.
FIREBASE_JOURNAL_USER_ID=your-firebase-user-uid

# Firebase Storage bucket (find in Firebase Console → Storage → gs://your-bucket.appspot.com)
FIREBASE_STORAGE_BUCKET=your-firebase-project-id.appspot.com

# Firestore collection name under users/{userId}/ (default: trades)
FIREBASE_JOURNAL_COLLECTION=trades

# Bot identity shown in journal entries
FIREBASE_BOT_NAME=HedgeHog Bot
FIREBASE_STRATEGY_NAME=Arbitrage Trading

# Account type written into Firestore — use: demo | live | prop
# Set "demo" during demo run; switch to "live" or "prop" for real capital
JOURNAL_ACCOUNT_TYPE=demo

# Broker name for display in journal (e.g. "Fusion Markets" or "FundingPips")
JOURNAL_BROKER=

# ── Screenshot settings ────────────────────────────────────────────────────
SCREENSHOT_ENABLED=true
SCREENSHOT_ONLY_FOR_TP_SL=true

# Dry-run: generate chart locally but skip upload (file:// URL written to log)
SCREENSHOT_DRY_RUN=true

SCREENSHOT_TIMEFRAME=M15
SCREENSHOT_LOOKBACK_BARS=120
SCREENSHOT_WIDTH=1600
SCREENSHOT_HEIGHT=900
SCREENSHOT_STORAGE=firebase
