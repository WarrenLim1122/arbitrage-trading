//@version=6
indicator("TEST-ONLY 15m Loop (Webhook Pinger)", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// ═══════════════════════════════════════════════════════════════════════════
//  ⚠️  TEST-ONLY — NOT A STRATEGY  ⚠️
// ───────────────────────────────────────────────────────────────────────────
//  Purpose: exercise the full Layer 1 → 2 → 3 pipeline on a DEMO account.
//
//  Behavior (no market analysis, no edge):
//    1. Fire a webhook + open a virtual trade in a random direction.
//    2. Wait until that virtual trade touches its own SL or TP (price action).
//    3. Remember which one was hit (TP / SL — the "memory placeholder").
//    4. Wait a random 1–5 bar gap, then fire the next trade. Repeat.
//
//  SL distance is sized as a % of price so it auto-scales across every
//  covered instrument (EURUSD GBPUSD USDCHF USDCAD USDJPY NZDUSD XAUUSD
//  XAGUSD NAS100) without per-chart tuning. The frozen production file
//  (`1D-15m Breakout INDICATOR.pine`) is untouched.
//
//  Reward/risk boxes are created at entry with width=1 bar and *extend
//  forward each bar while the trade is open*, freezing the moment SL or TP
//  is touched. That keeps the chart readable even when trades cycle fast.
//
//  DO NOT attach this to any chart once real capital is live.
//  Note: TradingView never fires alerts on historical bars — webhooks start
//  once you create the alert and a new 15m bar closes.
// ═══════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════
bool   inEnabled    = input.bool(true,   "Enabled (master kill switch)")
int    inMaxPerDay  = input.int(20,      "Max signals per UTC day", minval=1)
float  inSlPercent  = input.float(0.10,  "SL distance (% of price)", minval=0.01, step=0.01, tooltip="0.10% ≈ 10 pips on EURUSD, ≈ $4.5 on XAUUSD at 4500, ≈ 22 pts on NAS100 at 22000. Auto-scales across instruments.")
float  inRR         = input.float(0.27,  "RR (TP = entry ± SL_dist × RR)", minval=0.01, step=0.01)
string inOrderType  = input.string("MARKET", "Order type", options=["MARKET", "LIMIT"])
bool   inShowTable  = input.bool(true,   "Show diagnostic table")

string pip_type = syminfo.ticker == "USDJPY" ? "jpy" : "standard"
float  pip_size = syminfo.ticker == "USDJPY" ? 0.01 : 0.0001

// ═══════════════════════════════════════════════════════════════════════════
// STATE
//   state: 0 = ARMED   1 = IN_TRADE   2 = COOLDOWN
//   lastCloseType: "TP" / "SL" / "—"  ← the requested memory placeholder
//   nextGap: bars to wait this cooldown (re-rolled per close, 1–5 inclusive)
// ═══════════════════════════════════════════════════════════════════════════
var int    state          = 0
var int    vDir           = 0
var float  vEntry         = na
var float  vSl            = na
var float  vTp            = na
var int    cooldownCount  = 0
var int    nextGap        = 1
var int    signalsToday   = 0
var int    lastDay        = na
var string lastCloseType  = "—"
var box    bxReward       = na
var box    bxRisk         = na
var line   lnEntry        = na
var line   lnSl           = na
var line   lnTp           = na

bool fireLong  = false
bool fireShort = false

// ═══════════════════════════════════════════════════════════════════════════
// STATE MACHINE — advances only on confirmed (closed) 15m bars so it stays
// in lock-step with alert.freq_once_per_bar_close.
// ═══════════════════════════════════════════════════════════════════════════
if barstate.isconfirmed
    // ── Daily cap reset (UTC) ─────────────────────────────────────────────
    int curDay = int(math.floor(time / 86400000.0))
    if na(lastDay) or curDay != lastDay
        signalsToday := 0
        lastDay      := curDay

    // ── 1. IN_TRADE → extend boxes/lines to this bar, then check touch ────
    if state == 1
        if not na(bxReward)
            box.set_right(bxReward, bar_index)
            box.set_right(bxRisk,   bar_index)
            line.set_x2(lnEntry, bar_index)
            line.set_x2(lnSl,    bar_index)
            line.set_x2(lnTp,    bar_index)
        bool hitTp = vDir == 1 ? high >= vTp : low  <= vTp
        bool hitSl = vDir == 1 ? low  <= vSl : high >= vSl
        if hitTp or hitSl
            lastCloseType := hitTp ? "TP" : "SL"
            state         := 2
            cooldownCount := 0
            nextGap       := int(math.random(1, 6))   // 1..5 inclusive

    // ── 2. COOLDOWN → tick down, then re-arm ──────────────────────────────
    else if state == 2
        cooldownCount += 1
        if cooldownCount >= nextGap
            state := 0

    // ── 3. ARMED → fire a webhook + open a new virtual trade ──────────────
    if state == 0 and inEnabled and signalsToday < inMaxPerDay
        int    dir     = math.random(0, 1) < 0.5 ? 1 : -1
        float  entryPx = close
        float  slDist  = entryPx * inSlPercent / 100.0
        float  slPx    = dir == 1 ? entryPx - slDist : entryPx + slDist
        float  tpPx    = dir == 1 ? entryPx + slDist * inRR : entryPx - slDist * inRR

        vDir     := dir
        vEntry   := entryPx
        vSl      := slPx
        vTp      := tpPx
        state    := 1
        signalsToday += 1
        fireLong  := dir == 1
        fireShort := dir == -1

        // Visualization — start as a 1-bar-wide marker; the IN_TRADE branch
        // above extends the right edge each subsequent bar until close.
        lnEntry := line.new(bar_index, entryPx, bar_index + 1, entryPx, color=color.white, style=line.style_solid)
        lnSl    := line.new(bar_index, slPx,    bar_index + 1, slPx,    color=color.red,   style=line.style_dashed)
        lnTp    := line.new(bar_index, tpPx,    bar_index + 1, tpPx,    color=color.green, style=line.style_dashed)
        if dir == 1
            bxReward := box.new(bar_index, tpPx,    bar_index + 1, entryPx, border_color=na, bgcolor=color.new(color.green, 85))
            bxRisk   := box.new(bar_index, entryPx, bar_index + 1, slPx,    border_color=na, bgcolor=color.new(color.red,   85))
        else
            bxReward := box.new(bar_index, entryPx, bar_index + 1, tpPx,    border_color=na, bgcolor=color.new(color.green, 85))
            bxRisk   := box.new(bar_index, slPx,    bar_index + 1, entryPx, border_color=na, bgcolor=color.new(color.red,   85))

        // Webhook payload — schema-identical to the production indicator so
        // Layer 2/3 see exactly the field set they already parse.
        // m15_swing_* are filled with the trigger bar's high/low as harmless
        // context placeholders; this test tool has no swing logic.
        string sigStr     = dir == 1 ? "LONG" : "SHORT"
        string trendStr   = dir == 1 ? "BULLISH" : "BEARISH"
        float  slPipsOut  = slDist / pip_size
        string payload = '{"signal":"' + sigStr + '","ticker":"' + syminfo.ticker + '","timestamp_ms":' + str.tostring(time) + ',"timeframe":"15m","entry":' + str.tostring(entryPx) + ',"sl":' + str.tostring(slPx) + ',"tp":' + str.tostring(tpPx) + ',"sl_pips":' + str.tostring(slPipsOut) + ',"sl_percent":' + str.tostring(inSlPercent) + ',"rr_ratio":' + str.tostring(inRR) + ',"order_type":"' + inOrderType + '","daily_trend":"' + trendStr + '","m15_swing_high":' + str.tostring(high) + ',"m15_swing_low":' + str.tostring(low) + ',"pip_type":"' + pip_type + '"}'
        alert(payload, alert.freq_once_per_bar_close)

// ═══════════════════════════════════════════════════════════════════════════
// VISUALS — entry-bar markers
// ═══════════════════════════════════════════════════════════════════════════
plotshape(fireLong,  title="LONG fired",  style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.small, text="L")
plotshape(fireShort, title="SHORT fired", style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.small, text="S")

// ═══════════════════════════════════════════════════════════════════════════
// DIAGNOSTIC TABLE
// ═══════════════════════════════════════════════════════════════════════════
var table panel = table.new(position.top_right, 2, 6, border_width=1, border_color=color.gray)

if barstate.islast and inShowTable
    string stateStr = not inEnabled ? "DISABLED" : state == 0 ? "ARMED" : state == 1 ? "IN TRADE" : "COOLDOWN"
    color  stateBg  = not inEnabled ? color.new(color.gray, 40) : state == 1 ? color.new(color.aqua, 40) : state == 2 ? color.new(color.orange, 40) : color.new(color.green, 40)

    table.cell(panel, 0, 0, "TEST-ONLY Loop", bgcolor=color.new(color.black, 10), text_color=color.yellow, text_size=size.small)
    table.cell(panel, 1, 0, stateStr, bgcolor=stateBg, text_color=color.white, text_size=size.small)

    table.cell(panel, 0, 1, "Last close", bgcolor=color.new(color.black, 20), text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 1, lastCloseType, bgcolor=color.new(color.black, 20), text_color=lastCloseType == "TP" ? color.lime : lastCloseType == "SL" ? color.red : color.silver, text_size=size.tiny)

    table.cell(panel, 0, 2, "Signals today", bgcolor=color.new(color.black, 20), text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 2, str.tostring(signalsToday) + " / " + str.tostring(inMaxPerDay), bgcolor=color.new(color.black, 20), text_color=signalsToday >= inMaxPerDay ? color.orange : color.white, text_size=size.tiny)

    table.cell(panel, 0, 3, "Cooldown left", bgcolor=color.new(color.black, 20), text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 3, state == 2 ? str.tostring(math.max(nextGap - cooldownCount, 0)) + " / " + str.tostring(nextGap) + " bar(s)" : "—", bgcolor=color.new(color.black, 20), text_color=color.white, text_size=size.tiny)

    table.cell(panel, 0, 4, "Virtual E / SL / TP", bgcolor=color.new(color.black, 20), text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 4, state == 1 ? str.tostring(vEntry, format.mintick) + " / " + str.tostring(vSl, format.mintick) + " / " + str.tostring(vTp, format.mintick) : "—", bgcolor=color.new(color.black, 20), text_color=color.white, text_size=size.tiny)

    table.cell(panel, 0, 5, "Order type", bgcolor=color.new(color.black, 20), text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 5, inOrderType, bgcolor=color.new(color.black, 20), text_color=color.white, text_size=size.tiny)
