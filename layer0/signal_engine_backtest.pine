//@version=6
strategy("1D/15m Mechanical Breakout Engine v7", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=1, commission_type=strategy.commission.percent, commission_value=0.0007, slippage=2, process_orders_on_close=true)

// ═══════════════════════════════════════════════════════════════════════════
//  PARAMETERS
// ═══════════════════════════════════════════════════════════════════════════
int   N_HTF = 2
int   N_LTF = 6
float RR    = 0.27

float pip_size = syminfo.ticker == "USDJPY" ? 0.01 : 0.0001
string pip_type = syminfo.ticker == "USDJPY" ? "jpy" : "standard"

// ═══════════════════════════════════════════════════════════════════════════
//  BULLETPROOF 1-DAY (HTF) EXTRACTION
// ═══════════════════════════════════════════════════════════════════════════
f_htf_state() =>
    ph = ta.pivothigh(high, N_HTF, N_HTF)
    pl = ta.pivotlow(low, N_HTF, N_HTF)
    
    ph1 = ta.valuewhen(not na(ph), ph, 0)
    ph2 = ta.valuewhen(not na(ph), ph, 1)
    ph3 = ta.valuewhen(not na(ph), ph, 2)
    
    pl1 = ta.valuewhen(not na(pl), pl, 0)
    pl2 = ta.valuewhen(not na(pl), pl, 1)
    pl3 = ta.valuewhen(not na(pl), pl, 2)
    
    [ph1, ph2, ph3, pl1, pl2, pl3]

// Switched to "D" for Daily data
[h_ph1, h_ph2, h_ph3, h_pl1, h_pl2, h_pl3] = request.security(syminfo.tickerid, "D", f_htf_state(), lookahead=barmerge.lookahead_off)

// ═══════════════════════════════════════════════════════════════════════════
//  FINE-TUNED TREND LOGIC (Sticky State)
// ═══════════════════════════════════════════════════════════════════════════
// 1. Identify specific structural pairs (2 consecutive required)
bool is_2hh = not na(h_ph3) and (h_ph1 > h_ph2) and (h_ph2 > h_ph3)
bool is_2hl = not na(h_pl3) and (h_pl1 > h_pl2) and (h_pl2 > h_pl3)

bool is_2lh = not na(h_ph3) and (h_ph1 < h_ph2) and (h_ph2 < h_ph3)
bool is_2ll = not na(h_pl3) and (h_pl1 < h_pl2) and (h_pl2 < h_pl3)

// 2. The Sticky Switch
var int htf_trend = 0

// If BOTH sides align bullish, lock into Uptrend
if is_2hh and is_2hl
    htf_trend := 1
// If BOTH sides align bearish, lock into Downtrend
else if is_2lh and is_2ll
    htf_trend := -1
// IMPLIED RULE: If only one side flips, the trend stays exactly what it was previously.

bool htf_bull = htf_trend == 1
bool htf_bear = htf_trend == -1

bgcolor(htf_bull ? color.new(color.green, 90) : htf_bear ? color.new(color.red, 90) : na, title="HTF Trend Background")

// ═══════════════════════════════════════════════════════════════════════════
//  DIAGNOSTIC DASHBOARD
// ═══════════════════════════════════════════════════════════════════════════
string raw_struct = (is_2hh and is_2hl) ? "FULL BULL" : (is_2lh and is_2ll) ? "FULL BEAR" : "MIXED (Holding Trend)"

var table diag_panel = table.new(position.top_right, 2, 4, border_width=1, border_color=color.gray)
table.cell(diag_panel, 0, 0, "Locked 1D Trend", bgcolor=color.new(color.black, 20), text_color=color.white, text_size=size.small)
table.cell(diag_panel, 1, 0, htf_trend == 1 ? "BULLISH" : htf_trend == -1 ? "BEARISH" : "WAITING", bgcolor=htf_trend == 1 ? color.new(color.green, 40) : htf_trend == -1 ? color.new(color.red, 40) : color.new(color.gray, 40), text_color=color.white, text_size=size.small)

table.cell(diag_panel, 0, 1, "Current 1D Struct", bgcolor=color.new(color.black, 20), text_color=color.silver, text_size=size.tiny)
table.cell(diag_panel, 1, 1, raw_struct, bgcolor=raw_struct == "MIXED (Holding Trend)" ? color.new(color.orange, 40) : color.new(color.black, 20), text_color=color.white, text_size=size.tiny)

table.cell(diag_panel, 0, 2, "Last 1D Highs", bgcolor=color.new(color.black, 20), text_color=color.silver, text_size=size.tiny)
table.cell(diag_panel, 1, 2, str.tostring(h_ph1, format.mintick) + " | " + str.tostring(h_ph2, format.mintick), bgcolor=color.new(color.black, 20), text_color=color.silver, text_size=size.tiny)

table.cell(diag_panel, 0, 3, "Last 1D Lows", bgcolor=color.new(color.black, 20), text_color=color.silver, text_size=size.tiny)
table.cell(diag_panel, 1, 3, str.tostring(h_pl1, format.mintick) + " | " + str.tostring(h_pl2, format.mintick), bgcolor=color.new(color.black, 20), text_color=color.silver, text_size=size.tiny)

// ═══════════════════════════════════════════════════════════════════════════
//  15-MINUTE (LTF) SWING DETECTION & LABELS
// ═══════════════════════════════════════════════════════════════════════════
float ltf_ph = ta.pivothigh(high, N_LTF, N_LTF)
float ltf_pl = ta.pivotlow(low, N_LTF, N_LTF)

var float prev_ltf_sh = na, var float prev_ltf_sl = na
var float last_ltf_sh = na, var float last_ltf_sl = na
var int   last_sh_idx = na, var int   last_sl_idx = na
var bool  long_fired  = false, var bool  short_fired = false

if not na(ltf_ph)
    float new_sh = high[N_LTF]
    string lbl_text = na(prev_ltf_sh) ? "SH" : (new_sh > prev_ltf_sh ? "HH" : "LH")
    label.new(bar_index[N_LTF], new_sh, lbl_text, color=color.new(color.orange, 40), style=label.style_label_down, textcolor=color.white, size=size.small)
    
    prev_ltf_sh := last_ltf_sh 
    last_ltf_sh := new_sh
    last_sh_idx := bar_index[N_LTF]
    long_fired  := false

if not na(ltf_pl)
    float new_sl = low[N_LTF]
    string lbl_text = na(prev_ltf_sl) ? "SL" : (new_sl > prev_ltf_sl ? "HL" : "LL")
    label.new(bar_index[N_LTF], new_sl, lbl_text, color=color.new(color.aqua, 40), style=label.style_label_up, textcolor=color.white, size=size.small)
    
    prev_ltf_sl := last_ltf_sl 
    last_ltf_sl := new_sl
    last_sl_idx := bar_index[N_LTF]
    short_fired := false

// ═══════════════════════════════════════════════════════════════════════════
//  ENTRY TRIGGERS & VISUALS
// ═══════════════════════════════════════════════════════════════════════════
bool can_long  = htf_bull and not long_fired  and not na(last_ltf_sh) and not na(last_ltf_sl) and strategy.position_size == 0
bool can_short = htf_bear and not short_fired and not na(last_ltf_sh) and not na(last_ltf_sl) and strategy.position_size == 0

bool long_sig  = can_long  and close > last_ltf_sh
bool short_sig = can_short and close < last_ltf_sl

if long_sig
    long_fired := true
    float entry_px = close
    float sl_px    = last_ltf_sl
    float risk     = entry_px - sl_px
    float tp_px    = entry_px + (risk * RR)
    float sl_pips  = math.abs(entry_px - sl_px) / pip_size
    
    strategy.entry("Long", strategy.long)
    strategy.exit("Exit Long", "Long", stop=sl_px, limit=tp_px)
    
    line.new(last_sh_idx, last_ltf_sh, bar_index + 2, last_ltf_sh, color=color.orange, style=line.style_dotted, width=2)
    line.new(bar_index, tp_px,    bar_index + 10, tp_px,    color=color.green, style=line.style_dashed)
    line.new(bar_index, entry_px, bar_index + 10, entry_px, color=color.white, style=line.style_solid)
    line.new(bar_index, sl_px,    bar_index + 10, sl_px,    color=color.red,   style=line.style_dashed)
    box.new(bar_index, tp_px, bar_index + 10, entry_px, border_color=na, bgcolor=color.new(color.green, 85))
    box.new(bar_index, entry_px, bar_index + 10, sl_px, border_color=na, bgcolor=color.new(color.red, 85))
    
    // Updated Payload to 15m
    string payload = '{"signal": "LONG", "ticker": "' + syminfo.ticker + '", "timestamp_ms": ' + str.tostring(time) + ', "timeframe": "15m", "entry": ' + str.tostring(entry_px) + ', "sl": ' + str.tostring(sl_px) + ', "tp": ' + str.tostring(tp_px) + ', "sl_pips": ' + str.tostring(sl_pips) + ', "rr_ratio": ' + str.tostring(RR) + ', "order_type": "MARKET", "daily_trend": "BULLISH", "m15_swing_high": ' + str.tostring(last_ltf_sh) + ', "m15_swing_low": ' + str.tostring(last_ltf_sl) + ', "pip_type": "' + pip_type + '"}'
    alert(payload, alert.freq_once_per_bar_close)

if short_sig
    short_fired := true
    float entry_px = close
    float sl_px    = last_ltf_sh
    float risk     = sl_px - entry_px
    float tp_px    = entry_px - (risk * RR)
    float sl_pips  = math.abs(entry_px - sl_px) / pip_size
    
    strategy.entry("Short", strategy.short)
    strategy.exit("Exit Short", "Short", stop=sl_px, limit=tp_px)
    
    line.new(last_sl_idx, last_ltf_sl, bar_index + 2, last_ltf_sl, color=color.aqua, style=line.style_dotted, width=2)
    line.new(bar_index, tp_px,    bar_index + 10, tp_px,    color=color.green, style=line.style_dashed)
    line.new(bar_index, entry_px, bar_index + 10, entry_px, color=color.white, style=line.style_solid)
    line.new(bar_index, sl_px,    bar_index + 10, sl_px,    color=color.red,   style=line.style_dashed)
    box.new(bar_index, entry_px, bar_index + 10, tp_px, border_color=na, bgcolor=color.new(color.green, 85))
    box.new(bar_index, sl_px, bar_index + 10, entry_px, border_color=na, bgcolor=color.new(color.red, 85))
    
    // Updated Payload to 15m
    string payload = '{"signal": "SHORT", "ticker": "' + syminfo.ticker + '", "timestamp_ms": ' + str.tostring(time) + ', "timeframe": "15m", "entry": ' + str.tostring(entry_px) + ', "sl": ' + str.tostring(sl_px) + ', "tp": ' + str.tostring(tp_px) + ', "sl_pips": ' + str.tostring(sl_pips) + ', "rr_ratio": ' + str.tostring(RR) + ', "order_type": "MARKET", "daily_trend": "BEARISH", "m15_swing_high": ' + str.tostring(last_ltf_sh) + ', "m15_swing_low": ' + str.tostring(last_ltf_sl) + ', "pip_type": "' + pip_type + '"}'
    alert(payload, alert.freq_once_per_bar_close)